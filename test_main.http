# ── Health ────────────────────────────────────────────────────────────────────
GET http://localhost:8001/health

###

# ── Generic cache: set a value ────────────────────────────────────────────────
POST http://localhost:8001/cache/set
Content-Type: application/json

{
  "key": "user:42",
  "value": {"name": "Alice", "role": "admin"},
  "ttl": 120
}

###

# ── Generic cache: get the value ──────────────────────────────────────────────
GET http://localhost:8001/cache/get/user:42

###

# ── Generic cache: delete a key ───────────────────────────────────────────────
DELETE http://localhost:8001/cache/delete/user:42

###

# ── News: first request → cache MISS (fetches from simulated DB) ──────────────
GET http://localhost:8001/news/1

###

# ── News: second request → cache HIT (returns from Redis instantly) ───────────
GET http://localhost:8001/news/1

###

# ── News: list by category ────────────────────────────────────────────────────
GET http://localhost:8001/news/list/1?page=1

###

# ── News: invalidate article cache ────────────────────────────────────────────
POST http://localhost:8001/news/1/invalidate

###

# ── News: after invalidation → cache MISS again ───────────────────────────────
GET http://localhost:8001/news/1

###

# ── Cache stats: see hit rate ─────────────────────────────────────────────────
GET http://localhost:8001/cache/stats

###

# ── Flush all news caches ─────────────────────────────────────────────────────
POST http://localhost:8001/news/flush-all

###

# ── Flush by pattern ─────────────────────────────────────────────────────────
DELETE http://localhost:8001/cache/flush/news:*

###

# ── Reset stats ──────────────────────────────────────────────────────────────
POST http://localhost:8001/cache/stats/reset
